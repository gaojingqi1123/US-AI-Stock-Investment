(function(){
  function killAgent(){
    document.querySelectorAll('a[href*="kimi.com"],a[href*="agent"],[class*="kimi"],[id*="kimi"],[class*="agent"],[id*="agent"]').forEach(function(el){
      el.style.cssText='display:none!important;visibility:hidden!important;opacity:0!important;width:0!important;height:0!important;position:absolute!important;left:-9999px!important;pointer-events:none!important';
      if(el.parentNode) try{el.parentNode.removeChild(el);}catch(e){}
    });
  }
  killAgent();
  setInterval(killAgent,50);
  document.addEventListener('DOMContentLoaded',killAgent);
  window.addEventListener('load',killAgent);
  setTimeout(killAgent,0);setTimeout(killAgent,100);setTimeout(killAgent,300);setTimeout(killAgent,500);setTimeout(killAgent,1000);setTimeout(killAgent,2000);
  if(window.MutationObserver){
    var obs=new MutationObserver(function(){killAgent();});
    if(document.body) obs.observe(document.body,{childList:true,subtree:true});
    else document.addEventListener('DOMContentLoaded',function(){obs.observe(document.body,{childList:true,subtree:true});});
  }
})();
